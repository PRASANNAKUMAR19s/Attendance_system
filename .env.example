# ─── Attendance System — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.

# ── Flask / API ────────────────────────────────────────────────────────────────
# Strong random string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-strong-random-key
JWT_SECRET_KEY=change-jwt-secret-in-production

# Set to "true" to enable Flask debug mode (NEVER true in production)
FLASK_DEBUG=false

# Port for the REST API server
API_PORT=5001

# ── Tutor credentials ─────────────────────────────────────────────────────────
TUTOR_USERNAME=tutor

# Plain-text fallback (only used when TUTOR_PASSWORD_HASH is not set)
TUTOR_PASSWORD=paavai123

# Bcrypt hash of the tutor password.
# Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'paavai123', bcrypt.gensalt()).decode())"
TUTOR_PASSWORD_HASH=

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
TUTOR_EMAIL=tutor@college.edu.in
HOD_EMAIL=hod@college.edu.in

# ── College / Department info ─────────────────────────────────────────────────
COLLEGE_NAME=Paavai Engineering College (Autonomous)
DEPARTMENT=Artificial Intelligence & Data Science
TUTOR_NAME=MR.M.SATHYA SUNDARAM
HOD_NAME=DR.A.MANIKANDAN

# ── Firebase ──────────────────────────────────────────────────────────────────
# Set USE_FIREBASE=true to use Firestore instead of local CSV files.
USE_FIREBASE=false

# Path to your Firebase Admin SDK service account JSON file.
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# Firebase Storage bucket name (e.g. your-project.appspot.com)
FIREBASE_STORAGE_BUCKET=

# ── Face recognition ─────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=70
DEFAULTER_THRESHOLD=75
